# ── InfluxDB Cloud (TSM / v2-compatible) ────────────────────────────────────
# Org: Srh | Bucket: uni | Region: eu-central-1 (AWS)
INFLUX_URL=https://eu-central-1-1.aws.cloud2.influxdata.com
INFLUX_ORG=Srh
INFLUX_BUCKET=uni
# Paste your All Access API token here (regenerate it first if it was ever
# shared outside your local machine — treat any previously-shared token as
# burned). NEVER commit this file with a real value filled in.
INFLUX_TOKEN=your_influxdb_all_access_token_here

# ── Grafana Cloud ────────────────────────────────────────────────────────────
# Stack URL — replace with your actual *.grafana.net URL.
GRAFANA_URL=https://vividcorridor1446.grafana.net/
# Paste your service account token here (regenerate it first if it was ever
# shared outside your local machine — treat any previously-shared token as
# burned). NEVER commit this file with a real value filled in.
GRAFANA_SERVICE_ACCOUNT_TOKEN=your_grafana_service_account_token_here

# ── App ──────────────────────────────────────────────────────────────────────
APP_PORT=8000
